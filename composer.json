{
    "name": "labrodev/dpop",
    "description": "RFC 9449 DPoP for Laravel — issues EC P-256-bound JWTs and verifies DPoP proofs on protected routes.",
    "keywords": [
        "labrodev",
        "laravel",
        "laravel-package",
        "dpop",
        "jwt",
        "rfc9449",
        "authentication",
        "proof-of-possession"
    ],
    "type": "library",
    "homepage": "https://github.com/labrodev/laravel-dpop",
    "license": "MIT",
    "authors": [
        {
            "name": "Labro Dev",
            "email": "contact@labrodev.com",
            "role": "Development Team"
        }
    ],
    "support": {
        "email": "admin@labrodev.com",
        "issues": "https://github.com/labrodev/laravel-dpop/issues",
        "source": "https://github.com/labrodev/laravel-dpop"
    },
    "require": {
        "php": "^8.4",
        "firebase/php-jwt": "^6.0",
        "illuminate/cache": "^12.0",
        "illuminate/http": "^12.0",
        "illuminate/pipeline": "^12.0",
        "illuminate/routing": "^12.0",
        "illuminate/support": "^12.0",
        "spatie/laravel-data": "^4.0",
        "spatie/laravel-package-tools": "^1.92",
        "web-token/jwt-library": "^3.4"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^10.0",
        "phpunit/phpunit": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "Labrodev\\Dpop\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Labrodev\\Dpop\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Labrodev\\Dpop\\DpopServiceProvider"
            ]
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "clear": "@php vendor/bin/testbench package:purge-skeleton --ansi",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "test": "vendor/bin/phpunit",
        "pint": "vendor/bin/pint",
        "pint:test": "vendor/bin/pint --test",
        "phpstan": "vendor/bin/phpstan analyse --memory-limit=512M",
        "ci": [
            "@composer run test",
            "@composer run pint:test",
            "@composer run phpstan"
        ],
        "format": "vendor/bin/pint",
        "analyse": "vendor/bin/phpstan analyse --memory-limit=512M"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
